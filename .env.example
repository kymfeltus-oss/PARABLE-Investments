# Copy this file to .env.local for local dev (gitignored).
# Supabase NEXT_PUBLIC_* values for production builds are in .env.production (tracked) for AWS/GitHub.
# Do not commit .env.local — it usually contains OPENAI_API_KEY and other secrets.

# --- PARABLE Study AI only: set this so nav and home show Study AI (Sanctuary, Table, Lab) ---
# NEXT_PUBLIC_APP_VARIANT=parable-study-ai

# --- Supabase (required for auth & The Table groups) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- OpenAI (required for AI Scholar: Theory Solver, De-Coder, Steel Man) ---
OPENAI_API_KEY=sk-...

# --- LiveKit (optional; only if you use live video / studio) ---
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=
# NEXT_PUBLIC_LIVEKIT_URL=
