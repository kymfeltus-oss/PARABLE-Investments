# Parable Investments — landing, /start, /info, LiveKit /meet.
#
# Investor intro video (portal + /info/intro): too large for GitHub; keep `public/videos/Investor Intro.mp4` locally
# or set a public HTTPS URL. Production default is in `.env.production` (Vercel Blob). Override here for local dev:
# NEXT_PUBLIC_INVESTOR_INTRO_VIDEO_URL=https://u7fkmtuvdvallnwg.public.blob.vercel-storage.com/Investor%20Intro.mp4
# Optional CDN for Investor Flash.mp4 (otherwise served from public/videos/).
# NEXT_PUBLIC_INVESTOR_FLASH_VIDEO_URL=https://example.com/Investor%20Flash.mp4

# Scheduled `/meet` welcome stage — `Live Meeting.mp4` (default `public/videos/Live Meeting.mp4`)
# NEXT_PUBLIC_LIVE_MEETING_INTRO_VIDEO_URL=https://example.com/Live-Meeting.mp4

# /investor/portal — proposal deck iframe (restart dev locally; Vercel: set env + redeploy)
# Prefer your white-labeled Gamma host (custom subdomain) — same path you get from Share → **Embed** → iframe `src`, but on your domain (faster DNS + no third-party chrome when branding is disabled in Gamma).
# Optional legacy: `https://gamma.app/embed/…` still works if you have not migrated the publish host yet.
# NEXT_PUBLIC_GAMMA_PROPOSAL_URL=https://yourproject.com
# Optional: open the embed at a specific Gamma card (skip an intro/calculator card). From Gamma: card “…” → Copy card link → use the #card-… fragment only.
# NEXT_PUBLIC_GAMMA_PROPOSAL_START_HASH=#card-xxxxxxxx
# Optional server-only alias (same embed URL; read at request time on server — no NEXT_PUBLIC_ prefix):
# GAMMA_EMBED_URL=https://yourproject.com
# Optional: proposal tab presentation video (defaults to public/videos/Proposal Presentation.mp4, then Investor Intro)
# NEXT_PUBLIC_PROPOSAL_PRESENTATION_VIDEO_URL=https://example.com/Your-Presentation.mp4

# Optional: public URL of the real Parable consumer app for /explore — iframe is the exact product UI when set.
# Staging or demo HTTPS URL. The app must allow embedding from this site (CSP frame-ancestors) if the iframe should load cross-origin.
# NEXT_PUBLIC_PARABLE_PROTOTYPE_URL=https://your-demo.parable.app

# LiveKit (https://cloud.livekit.io) — required for /meet video rooms
# Use WebSocket URL (wss://…). If you paste https://… from the dashboard, the app normalizes it to wss://.
# Server URL: set ONE of these (meet page reads NEXT_PUBLIC first, then LIVEKIT_URL).
# Use full wss://… or only the host (e.g. your-project.livekit.cloud) — the app prepends wss:// when needed.
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_URL=your-project.livekit.cloud
# Token API (server-only — never NEXT_PUBLIC_):
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# Scheduled session: default room suffix when opening /meet?join=scheduled (full room = investor-<suffix>)
# NEXT_PUBLIC_SCHEDULED_MEET_ROOM_SUFFIX=feb-deck-review

# Parable staff host key for /meet?join=scheduled (server-only; compared in /api/meeting/verify-join).
# When set, booking confirmation emails include this key plus the room suffix for the Parable team join path.
# Keep the value secret — anyone with this key can join scheduled rooms as staff.
# MEETING_MASTER_KEY=generate-a-long-random-secret

# Optional: single "master access" passphrase for /meet?join=scheduled — bypasses booking DB + team host key.
# When set, the "Parable — master access" path accepts only this key (no email, room, or meeting registration).
# PARABLE_MASTER_BYPASS_KEY=your-secret-phrase

# Request-a-meeting: shown on /start
# NEXT_PUBLIC_INVESTOR_CONTACT_EMAIL=investors@parableinvestments.com
# Booking (/book): NDA row in Supabase + optional Cal embed + confirmation email via Resend
# RESEND_API_KEY: required to send. RESEND_FROM_EMAIL: optional; if missing/invalid, the app uses NEXT_PUBLIC_INVESTOR_CONTACT_EMAIL (default investors@parableinvestments.com) as the From address when it is a valid address on your Resend domain.
# Without RESEND_API_KEY, registration still saves but no email is sent (see /api/meeting/register).
# With them set: `RESEND_FROM_EMAIL` must use a domain you verified in Resend (DNS), or Resend returns an error and no mail is delivered.
# Get API key: https://resend.com — verify a domain or use Resend's onboarding sender; FROM must be a verified domain/sender.
# NEXT_PUBLIC_SITE_URL=https://parableinvestments.com   # used in meeting links in emails
# NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/yourname/investor-call   # Cal.com auto-adds ?embed=true
# NEXT_PUBLIC_SCHEDULING_EMBED_URL=   # optional override for iframe src (Calendly embed URL, etc.)
# RESEND_API_KEY=re_xxxxxxxx
# The re_ key belongs ONLY in RESEND_API_KEY — never put it in RESEND_FROM_EMAIL (Resend 422: invalid "from").
# RESEND_FROM_EMAIL=Parable <meetings@your-verified-domain.com>
# NDA: after signing, PDF copies go to the signatory, NEXT_PUBLIC_INVESTOR_CONTACT_EMAIL (default investors@parableinvestments.com), and this staff inbox (default kymfeltus@gmail.com).
# NDA_STAFF_EMAIL=kymfeltus@gmail.com
# Optional: placeholder .ics reminder in confirmation email (hours from send, length in minutes)
# MEETING_CONFIRMATION_CALENDAR_OFFSET_HOURS=24
# MEETING_CONFIRMATION_CALENDAR_DURATION_MINUTES=60

# Supabase — Legal Gate (/investor), magic link, /nda agreement storage (see docs/SUPABASE_SETUP.md)
# Required for POST /api/investor/agreement (NDA submit): URL + service role key + run supabase/schema-investor-agreements.sql
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # public anon key (Auth + SSR cookies)
# SUPABASE_SERVICE_ROLE_KEY=       # server only — required for investor_agreements inserts; never expose or NEXT_PUBLIC_
# Legacy alias (optional): SUPABASE_URL — same value as NEXT_PUBLIC_SUPABASE_URL

# Optional: Vercel sets VERCEL_GIT_COMMIT_SHA; local git SHA via next.config.js.
