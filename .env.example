# Copy this file to .env.local for local dev (gitignored).
# Supabase NEXT_PUBLIC_* values for production builds are in .env.production (tracked) for AWS/GitHub.
# Do not commit .env.local — it usually contains OPENAI_API_KEY and other secrets.

# --- PARABLE Study AI only: set this so nav and home show Study AI (Sanctuary, Table, Lab) ---
# NEXT_PUBLIC_APP_VARIANT=parable-study-ai

# --- Liveness simulation (ticker, toasts, follower creep, flash-mob stats). Production: use 0. Dev defaults on unless 0. ---
# NEXT_PUBLIC_LIVENESS_SIMULATION=0

# --- Testify (/testify) demo feed: fake community posts for UI feel. Default off (same as prod); set true to preview. ---
# NEXT_PUBLIC_TESTIFY_DEMO_FEED=true

# --- Supabase (required for auth & The Table groups) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: set to 1 so the browser uses /supabase-proxy (Next rewrite) when *.supabase.co is blocked. Default is direct URL (recommended).
# NEXT_PUBLIC_SUPABASE_BROWSER_RELAY=1

# Supabase Storage image transforms (resize/WebP) via the render API.
# Leave unset or non-zero so avatars/feeds use `/storage/v1/render/image/public/` (avoids ~29MB object/public fetches).
# `=0` only skips optimization for non-Supabase third-party URLs; Supabase Storage URLs are still forced through render.
# NEXT_PUBLIC_SUPABASE_IMAGE_TRANSFORM=0

# Emergency: on /my-sanctuary, skip non-essential remote avatar images + defer registered profile fetch until the gate opens.
# NEXT_PUBLIC_MY_SANCTUARY_EMERGENCY_IMAGE_SUPPRESS=1

# Post flow stabilization: trim testimony wall, live cards, curated block, fellowship rail, and heavy remote avatars on /my-sanctuary. Set to 0 to disable.
# NEXT_PUBLIC_POST_FLOW_STABILIZATION=0

# Emergency bandwidth: on /my-sanctuary, keep Fellowship + non-hero remote avatars off until the post flow is stable. Default on; set to 0 to restore full rail.
# NEXT_PUBLIC_POST_FLOW_BANDWIDTH_EMERGENCY=0

# --- OpenAI (required for AI Scholar: Theory Solver, De-Coder, Steel Man) ---
OPENAI_API_KEY=sk-...

# --- LiveKit (live studio: /live-studio, POST /api/livekit/token) ---
# Server-only: key + secret. URL is safe to expose; use same wss host for both.
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-project.livekit.cloud
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# NEXT_PUBLIC_TESTIFY_DEMO_FEED=true
