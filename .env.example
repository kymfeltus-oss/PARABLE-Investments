# Parable Investments — landing, /start, /info, LiveKit /meet.

# LiveKit (https://cloud.livekit.io) — required for /meet video rooms
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# Scheduled session: default room suffix when opening /meet?join=scheduled (full room = investor-<suffix>)
# NEXT_PUBLIC_SCHEDULED_MEET_ROOM_SUFFIX=feb-deck-review

# Request-a-meeting: shown on /start
# NEXT_PUBLIC_INVESTOR_CONTACT_EMAIL=investors@parableinvestments.com
# Booking (/book): NDA evidence row + Resend confirmation + embedded Cal.com calendar
# NEXT_PUBLIC_SITE_URL=https://parableinvestments.com   # used in meeting links in emails
# NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/yourname/investor-call   # Cal.com auto-adds ?embed=true
# NEXT_PUBLIC_SCHEDULING_EMBED_URL=   # optional override for iframe src (Calendly embed URL, etc.)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Parable <meetings@your-verified-domain.com>

# Supabase — Legal Gate (/investor), magic link, /nda agreements (see supabase/*.sql)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # public anon key (Auth + SSR cookies)
# SUPABASE_SERVICE_ROLE_KEY=       # server only — inserts legal_signatures / investor_agreements / meeting_nda_evidence; never NEXT_PUBLIC_
# Legacy alias (optional): SUPABASE_URL — same value as NEXT_PUBLIC_SUPABASE_URL

# Optional: Vercel sets VERCEL_GIT_COMMIT_SHA; local git SHA via next.config.js.
