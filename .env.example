# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — required for signed agreement PDF emails
# Get API key: https://resend.com/api-keys
# Dev: use onboarding@resend.dev as FROM (Resend only delivers to your account email until you verify a domain)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pitch Lock <onboarding@resend.dev>
# Optional: presenter copy when pitch has no presenter_email
OWNER_ALERT_EMAIL=

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Session (future auth)
SESSION_JWT_SECRET=
